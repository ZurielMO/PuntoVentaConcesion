# PuntoVentaFront — variables de entorno
# Copia a .env.local y completa con valores reales.

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
# Local / Vercel (recomendado): el browser usa `/api` (BFF) y el servidor
# proxea con API_BASE_URL. NO definas NEXT_PUBLIC_API_BASE_URL en Vercel.
#
# Local (backend con npm run dev):
# API_BASE_URL=http://localhost:3000/api
#
# Producción (Cloud Function Gen2) — sin slash final:
API_BASE_URL=https://us-central1-puntoventacl.cloudfunctions.net/apiV2
#
# Solo para export FTP / hosting estático (sin BFF):
# NEXT_PUBLIC_API_BASE_URL=https://us-central1-puntoventacl.cloudfunctions.net/apiV2

# URL pública del frontend (CORS en backend, opcional si usas BFF)
STORE_PUBLIC_BASE_URL=http://localhost:9002
# Vercel (después del primer deploy, pon tu URL real):
# STORE_PUBLIC_BASE_URL=https://tu-proyecto.vercel.app
# FTP:
# STORE_PUBLIC_BASE_URL=https://concesiones.clubleon.mx
# NEXT_PUBLIC_SITE_URL=https://concesiones.clubleon.mx

# ---------------------------------------------------------------------------
# Vercel — Environment Variables (Production + Preview)
# ---------------------------------------------------------------------------
# API_BASE_URL=https://us-central1-puntoventacl.cloudfunctions.net/apiV2
# NEXT_PUBLIC_AUTH_FIREBASE_API_KEY=...
# NEXT_PUBLIC_AUTH_FIREBASE_AUTH_DOMAIN=puntoventacl.firebaseapp.com
# NEXT_PUBLIC_AUTH_FIREBASE_PROJECT_ID=puntoventacl
# NEXT_PUBLIC_AUTH_FIREBASE_APP_ID=...
# (opcional) NEXT_PUBLIC_AUTH_FIREBASE_STORAGE_BUCKET=...
# (opcional) NEXT_PUBLIC_AUTH_FIREBASE_MESSAGING_SENDER_ID=...
# Framework Preset: Next.js | Build: npm run build | Output: (default)

# ---------------------------------------------------------------------------
# Firebase Auth (proyecto puntoventacl)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_FIREBASE_API_KEY=
NEXT_PUBLIC_AUTH_FIREBASE_AUTH_DOMAIN=puntoventacl.firebaseapp.com
NEXT_PUBLIC_AUTH_FIREBASE_PROJECT_ID=puntoventacl
NEXT_PUBLIC_AUTH_FIREBASE_STORAGE_BUCKET=puntoventacl.firebasestorage.app
NEXT_PUBLIC_AUTH_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_AUTH_FIREBASE_APP_ID=

# App Check (opcional)
NEXT_PUBLIC_FIREBASE_APP_CHECK_SITE_KEY=

# ---------------------------------------------------------------------------
# Pagos / Maps / Sentry (futuro)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_SENTRY_DSN=
